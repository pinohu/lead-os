{
  "name": "neatcircle",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "node --test --test-concurrency=1 --test-isolation=none --experimental-strip-types tests/**/*.test.ts",
    "bootstrap-client": "node scripts/bootstrap-client.mjs",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare build && wrangler dev",
    "cf:deploy": "opennextjs-cloudflare build && wrangler deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "next": "^15.3.3",
    "react": "^19.2.5",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.8.0",
    "@tailwindcss/postcss": "^4.1.7",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "tailwindcss": "^4.1.7",
    "typescript": "5.9.3",
    "wrangler": "^4.31.0"
  }
}
