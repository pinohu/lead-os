# ==============================================================================
# NeatCircle Edge Layer - Environment Variables
# ==============================================================================
# Copy this file to .env.local and fill in your values.
# Variables marked [REQUIRED] must be set for core functionality.
# Variables marked [RECOMMENDED] have defaults but should be customized.
# Variables marked [OPTIONAL] enable additional features when present.
# ==============================================================================

# ------------------------------------------------------------------------------
# Tenant Identity and Branding
# ------------------------------------------------------------------------------
# Select a pre-built client preset. Overrides all brand defaults below.
# [OPTIONAL] Default: uses built-in default preset
# NEXT_PUBLIC_TENANT_PRESET=neatcircle
# TENANT_PRESET=neatcircle

# Public brand name displayed across the site.
# [RECOMMENDED]
NEXT_PUBLIC_BRAND_NAME=NeatCircle

# Secondary brand name (used in subtitles and legal contexts).
# [OPTIONAL]
# NEXT_PUBLIC_SECONDARY_BRAND_NAME=

# Legal entity name for footer and legal pages.
# [OPTIONAL]
# NEXT_PUBLIC_LEGAL_NAME=

# Brand primary color (hex).
# [OPTIONAL]
# NEXT_PUBLIC_BRAND_PRIMARY=#1a1a2e

# Brand accent color (hex).
# [OPTIONAL]
# NEXT_PUBLIC_BRAND_ACCENT=#14b8a6

# Public-facing site URL. Used in emails, OG tags, and canonical URLs.
# [RECOMMENDED]
NEXT_PUBLIC_SITE_URL=https://neatcircle.com

# Support email address.
# [RECOMMENDED]
NEXT_PUBLIC_SUPPORT_EMAIL=support@neatcircle.com

# Admin email for internal notifications (not exposed to the public).
# [OPTIONAL]
# ADMIN_EMAIL=admin@neatcircle.com

# Tenant tag for data isolation in shared backends.
# [OPTIONAL]
# TENANT_TAG=neatcircle

# Client portal URL (SuiteDash or similar).
# [OPTIONAL]
# NEXT_PUBLIC_PORTAL_URL=https://portal.neatcircle.com

# Email sender address for transactional emails.
# [OPTIONAL] Default: automations@{site domain}
# FROM_EMAIL=automations@neatcircle.com

# ------------------------------------------------------------------------------
# Marketing Copy
# ------------------------------------------------------------------------------
# Hero headline on the landing page.
# [OPTIONAL]
# NEXT_PUBLIC_MARKETING_HEADLINE=Your Custom Headline

# Meta description for SEO.
# [OPTIONAL]
# NEXT_PUBLIC_MARKETING_DESCRIPTION=Your meta description here

# Open Graph description for social sharing.
# [OPTIONAL]
# NEXT_PUBLIC_OPEN_GRAPH_DESCRIPTION=Your OG description here

# ------------------------------------------------------------------------------
# Service Configuration
# ------------------------------------------------------------------------------
# Comma-separated list of enabled service slugs displayed on the site.
# [OPTIONAL] Default: uses preset's enabled services
# NEXT_PUBLIC_ENABLED_SERVICES=process-automation,ai-integration,systems-integration

# Comma-separated list of featured core service slugs for the homepage.
# [OPTIONAL]
# NEXT_PUBLIC_FEATURED_CORE_SERVICES=process-automation,ai-integration

# Comma-separated list of featured blue ocean service slugs.
# [OPTIONAL]
# NEXT_PUBLIC_FEATURED_BLUE_OCEAN_SERVICES=

# Comma-separated list of featured industry slugs.
# [OPTIONAL]
# NEXT_PUBLIC_FEATURED_INDUSTRIES=

# ------------------------------------------------------------------------------
# CRM - SuiteDash
# ------------------------------------------------------------------------------
# SuiteDash API credentials for contact and company management.
# [REQUIRED]
SUITEDASH_PUBLIC_ID=
SUITEDASH_SECRET_KEY=

# ------------------------------------------------------------------------------
# Email - Emailit
# ------------------------------------------------------------------------------
# Emailit API key for transactional emails (welcome, nurture, conversion).
# [REQUIRED]
EMAILIT_API_KEY=

# ------------------------------------------------------------------------------
# Ledger - AITable
# ------------------------------------------------------------------------------
# AITable credentials for lead and event tracking.
# [REQUIRED]
AITABLE_API_TOKEN=
AITABLE_DATASHEET_ID=

# ------------------------------------------------------------------------------
# WhatsApp - WBizTool
# ------------------------------------------------------------------------------
# [OPTIONAL]
WBIZTOOL_API_KEY=
WBIZTOOL_INSTANCE_ID=

# ------------------------------------------------------------------------------
# Alerts - Discord
# ------------------------------------------------------------------------------
# Channel-specific Discord webhook URLs.
# [OPTIONAL]
# DISCORD_NEW_LEADS_WEBHOOK=
# DISCORD_ERRORS_WEBHOOK=
# DISCORD_WINS_WEBHOOK=
# DISCORD_HIGH_VALUE_WEBHOOK=

# ------------------------------------------------------------------------------
# Alerts - Telegram
# ------------------------------------------------------------------------------
# Telegram bot token and channel-specific chat IDs.
# [OPTIONAL]
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_NEW_LEADS_CHAT=
# TELEGRAM_ERRORS_CHAT=
# TELEGRAM_WINS_CHAT=
# TELEGRAM_HIGH_VALUE_CHAT=

# ------------------------------------------------------------------------------
# Automation - Boost.space / Make
# ------------------------------------------------------------------------------
# [OPTIONAL]
# BOOST_API_KEY=
# MAKE_API_TOKEN=

# ------------------------------------------------------------------------------
# Dashboard
# ------------------------------------------------------------------------------
# Secret for authenticating dashboard metrics API requests.
# If unset, requests are validated by same-origin check.
# [OPTIONAL]
# DASHBOARD_SECRET=

# ------------------------------------------------------------------------------
# Cron Authentication
# ------------------------------------------------------------------------------
# Secret for authenticating cron job requests.
# [RECOMMENDED]
CRON_SECRET=change-me-to-a-random-string

# ------------------------------------------------------------------------------
# Stripe
# ------------------------------------------------------------------------------
# Stripe API keys for payment processing.
# [REQUIRED for payments]
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ------------------------------------------------------------------------------
# CallScaler
# ------------------------------------------------------------------------------
# [OPTIONAL]
# CALLSCALER_API_KEY=

# ------------------------------------------------------------------------------
# UpViral
# ------------------------------------------------------------------------------
# [OPTIONAL]
# UPVIRAL_API_KEY=
# UPVIRAL_CAMPAIGN_URL=

# ------------------------------------------------------------------------------
# AgenticFlow
# ------------------------------------------------------------------------------
# [OPTIONAL]
# AGENTICFLOW_API_KEY=

# ------------------------------------------------------------------------------
# Automation API
# ------------------------------------------------------------------------------
# Secret for authenticating automation API requests.
# [OPTIONAL]
# AUTOMATION_API_SECRET=
