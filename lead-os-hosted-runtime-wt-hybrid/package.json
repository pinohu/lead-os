{
  "name": "lead-os-hosted-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "lead-os": "./src/cli/index.ts",
    "lead-os-mcp": "./src/mcp/index.ts"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p ${PORT:-3000}",
    "cli": "node --experimental-strip-types src/cli/index.ts",
    "mcp": "node --experimental-strip-types src/mcp/index.ts",
    "test": "cross-env LEAD_OS_USE_AITABLE_PERSISTENCE=false LEAD_OS_ENABLE_LIVE_SENDS=false node --test --test-concurrency=1 --test-isolation=none --experimental-strip-types tests/**/*.test.ts",
    "test:ci": "cross-env LEAD_OS_USE_AITABLE_PERSISTENCE=false LEAD_OS_ENABLE_LIVE_SENDS=false node --test --test-concurrency=1 --test-isolation=none --experimental-strip-types tests/**/*.test.ts"
  },
  "dependencies": {
    "bullmq": "^5.71.1",
    "next": "^16.2.1",
    "pg": "^8.20.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "stripe": "^21.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "cross-env": "^7.0.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pinohu/lead-os.git"
  },
  "license": "MIT",
  "homepage": "https://github.com/pinohu/lead-os#readme",
  "bugs": {
    "url": "https://github.com/pinohu/lead-os/issues"
  }
}
