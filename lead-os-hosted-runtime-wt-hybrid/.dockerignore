# =============================================================================
# .dockerignore — files excluded from the Docker build context
#
# Keeping the context lean speeds up `docker build` (less data sent to daemon)
# and prevents secrets / local state from leaking into the image.
# =============================================================================

# ---------- Version control --------------------------------------------------
.git
.gitignore
.gitattributes

# ---------- Node modules (rebuilt inside the image) --------------------------
node_modules

# ---------- Next.js build output (rebuilt inside the image) ------------------
.next
out
dist

# ---------- Secrets and environment files ------------------------------------
.env
.env.*
!.env.sample

# ---------- Local dev / editor artifacts -------------------------------------
.DS_Store
Thumbs.db
*.log
*.local
.vscode
.idea

# ---------- Test artifacts ---------------------------------------------------
tests
coverage
.nyc_output

# ---------- Documentation and CI config (not needed at runtime) --------------
*.md
docs
.github
logs

# ---------- Docker files themselves (no need to copy into the image) ---------
Dockerfile
docker-compose*.yml
.dockerignore

# ---------- TypeScript build cache -------------------------------------------
tsconfig.tsbuildinfo
*.tsbuildinfo

# ---------- Project-specific exclusions --------------------------------------
_n8n_sources
make-scenarios
neatcircle-beta
Funnel Blueprints
