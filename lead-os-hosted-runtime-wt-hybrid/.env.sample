# ==============================================================================
# Lead OS Hosted Runtime - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your values.
# Variables marked [REQUIRED] must be set for the runtime to function.
# Variables marked [RECOMMENDED] have defaults but should be customized.
# Variables marked [OPTIONAL] enable additional integrations when present.
# ==============================================================================

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
# PostgreSQL connection string. The runtime auto-creates tables on first access.
# If unset, the runtime falls back to in-memory storage (not suitable for production).
# [REQUIRED for production]
LEAD_OS_DATABASE_URL=postgresql://user:password@localhost:5432/lead_os

# Alternative connection variable names (checked as fallbacks)
# DATABASE_URL=
# POSTGRES_URL=

# ------------------------------------------------------------------------------
# Tenant Identity
# ------------------------------------------------------------------------------
# Unique tenant identifier. Isolates data across deployments.
# [RECOMMENDED] Default: "default-tenant"
LEAD_OS_TENANT_ID=my-tenant

# Public brand name displayed in widgets and emails.
# [RECOMMENDED] Default: "Lead OS"
NEXT_PUBLIC_BRAND_NAME=Lead OS

# Public-facing site URL. Used for magic links, widget boot config, and CTA destinations.
# [RECOMMENDED] Default: "https://lead-os.example"
NEXT_PUBLIC_SITE_URL=https://lead-os.example

# Support email address. Also used as a default operator email.
# [RECOMMENDED] Default: "support@lead-os.example"
NEXT_PUBLIC_SUPPORT_EMAIL=support@lead-os.example

# Brand accent color (hex). Used in widget theming.
# [OPTIONAL] Default: "#14b8a6"
NEXT_PUBLIC_BRAND_ACCENT=#14b8a6

# ------------------------------------------------------------------------------
# Feature Configuration
# ------------------------------------------------------------------------------
# Default service identifier for lead routing.
# [OPTIONAL] Default: "lead-capture"
LEAD_OS_DEFAULT_SERVICE=lead-capture

# Default niche slug. Determines which niche catalog entry loads by default.
# [OPTIONAL] Default: "general"
LEAD_OS_DEFAULT_NICHE=general

# Comma-separated list of enabled funnel families.
# Available: lead-magnet, qualification, chat, webinar, authority, checkout,
#            retention, rescue, referral, continuity
# [OPTIONAL] Default: all 10 families enabled
LEAD_OS_ENABLED_FUNNELS=lead-magnet,qualification,chat,webinar,authority,checkout,retention,rescue,referral,continuity

# Comma-separated list of allowed widget embed origins.
# If empty, all origins are allowed (open CORS).
# [RECOMMENDED for production]
LEAD_OS_WIDGET_ORIGINS=https://example.com,https://www.example.com

# ------------------------------------------------------------------------------
# CRM - SuiteDash
# ------------------------------------------------------------------------------
# SuiteDash API credentials for contact sync and pipeline management.
# [REQUIRED]
SUITEDASH_PUBLIC_ID=
SUITEDASH_SECRET_KEY=

# ------------------------------------------------------------------------------
# Email - Emailit
# ------------------------------------------------------------------------------
# Emailit API key for transactional email (magic links, nurture, notifications).
# [REQUIRED]
EMAILIT_API_KEY=

# ------------------------------------------------------------------------------
# WhatsApp - WBizTool
# ------------------------------------------------------------------------------
# WBizTool API credentials for WhatsApp messaging.
# Channel is auto-enabled when both values are set.
# [OPTIONAL]
WBIZTOOL_API_KEY=
WBIZTOOL_INSTANCE_ID=

# ------------------------------------------------------------------------------
# SMS - EasyTextMarketing
# ------------------------------------------------------------------------------
# EasyTextMarketing API key for SMS messaging.
# Channel is auto-enabled when any of these values are set.
# [OPTIONAL]
EASY_TEXT_MARKETING_API_KEY=
# EASYTEXTMARKETING_API_KEY=               # Alternative key name
# EASY_TEXT_MARKETING_WEBHOOK_URL=          # Webhook-based SMS trigger
# EASYTEXTMARKETING_WEBHOOK_URL=            # Alternative webhook key name

# ------------------------------------------------------------------------------
# SMS - SMSit (alternative SMS provider)
# ------------------------------------------------------------------------------
# [OPTIONAL]
# SMSIT_API_KEY=
# SMSIT_BASE_URL=

# ------------------------------------------------------------------------------
# Chat AI - Insighto
# ------------------------------------------------------------------------------
# Insighto API credentials for AI chat agent.
# Channel is auto-enabled when any of these values are set.
# [OPTIONAL]
INSIGHTO_API_KEY=
# INSIGHTO_WEBHOOK_URL=                    # Webhook trigger URL
# INSIGHTO_AGENT_WEBHOOK_URL=              # Agent-specific webhook
# INSIGHTO_AGENT_ID=                       # Agent identifier
# INSIGHTO_BOT_ID=                         # Bot identifier (alternative)

# ------------------------------------------------------------------------------
# Voice AI - Thoughtly
# ------------------------------------------------------------------------------
# Thoughtly API credentials for AI voice calls.
# Channel is auto-enabled when any of these values are set.
# [OPTIONAL]
THOUGHTLY_API_KEY=
# THOUGHTLY_WEBHOOK_URL=                   # Webhook trigger URL
# THOUGHTLY_AGENT_WEBHOOK_URL=             # Agent-specific webhook
# THOUGHTLY_AGENT_ID=                      # Agent identifier
# THOUGHTLY_FLOW_ID=                       # Flow identifier (alternative)

# ------------------------------------------------------------------------------
# Automation - n8n
# ------------------------------------------------------------------------------
# n8n connection for workflow orchestration.
# The runtime can connect via API, webhook, or MCP.
# [OPTIONAL]
N8N_BASE_URL=https://your-n8n.example.com/api/v1
N8N_API_KEY=

# Direct webhook URL for event fanout (alternative to API).
# N8N_WEBHOOK_URL=

# MCP (Model Context Protocol) connection for n8n.
# N8N_MCP_URL=
# N8N_MCP_ACCESS_TOKEN=

# ------------------------------------------------------------------------------
# Booking - Trafft
# ------------------------------------------------------------------------------
# Trafft API credentials for appointment booking.
# Supports OAuth client credentials or direct bearer token.
# [OPTIONAL]
TRAFFT_API_URL=https://your-tenant.admin.trafft.com
TRAFFT_CLIENT_ID=
TRAFFT_CLIENT_SECRET=

# Direct bearer token (skips OAuth flow if set).
# TRAFFT_BEARER_TOKEN=

# Public booking URL for customer-facing links.
# TRAFFT_BOOKING_URL=

# Default service ID for bookings. Override per-niche with TRAFFT_SERVICE_MAP.
# TRAFFT_DEFAULT_SERVICE_ID=

# JSON mapping of niche slugs to Trafft service IDs.
# Example: {"plumbing": "svc_abc", "hvac": "svc_def"}
# TRAFFT_SERVICE_MAP={}

# ------------------------------------------------------------------------------
# Booking - Lunacal (alternative)
# ------------------------------------------------------------------------------
# [OPTIONAL]
# LUNACAL_API_KEY=
# LUNACAL_BOOKING_URL=

# ------------------------------------------------------------------------------
# Documents - Documentero
# ------------------------------------------------------------------------------
# Documentero API key for PDF/document generation (proposals, agreements).
# [OPTIONAL]
DOCUMENTERO_API_KEY=

# Template IDs for different document types.
# DOCUMENTERO_TEMPLATE_ID=                 # Default template
# DOCUMENTERO_TEMPLATE_PROPOSAL_ID=        # Proposal template
# DOCUMENTERO_TEMPLATE_AGREEMENT_ID=       # Agreement template
# DOCUMENTERO_TEMPLATE_ONBOARDING_ID=      # Onboarding template

# Output format. Default: "pdf"
# DOCUMENTERO_DEFAULT_FORMAT=pdf

# Webhook URL for document generation notifications.
# DOCUMENTERO_WEBHOOK_URL=

# ------------------------------------------------------------------------------
# Documents - Crove (alternative)
# ------------------------------------------------------------------------------
# [OPTIONAL]
# CROVE_API_KEY=
# CROVE_BASE_URL=
# CROVE_WEBHOOK_URL=
# CROVE_TEMPLATE_ID=
# CROVE_TEMPLATE_PROPOSAL_ID=
# CROVE_TEMPLATE_AGREEMENT_ID=
# CROVE_TEMPLATE_ONBOARDING_ID=

# ------------------------------------------------------------------------------
# Commerce - ThriveCart
# ------------------------------------------------------------------------------
# ThriveCart API key for checkout and payment processing.
# [OPTIONAL]
# THRIVECART_API_KEY=
# THRIVECART_WEBHOOK_SECRET=
# THRIVECART_CHECKOUT_URL=
# THRIVECART_WEBHOOK_URL=

# ------------------------------------------------------------------------------
# Billing - Stripe
# ------------------------------------------------------------------------------

# Set true in production when checkout/subscription access should block protected routes.
# [OPTIONAL] Default: false in local templates; production vaults should set true.
LEAD_OS_BILLING_ENFORCE=false

# Stripe server keys for live checkout and trusted webhook handling.
# [REQUIRED FOR PRODUCTION BILLING]
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ------------------------------------------------------------------------------
# Referral - Partnero
# ------------------------------------------------------------------------------
# Partnero program ID for affiliate/referral tracking.
# [OPTIONAL]
PARTNERO_PROGRAM_ID=
# PARTNERO_API_KEY=
# PARTNERO_WEBHOOK_URL=

# ------------------------------------------------------------------------------
# Referral - UpViral
# ------------------------------------------------------------------------------
# [OPTIONAL]
# UPVIRAL_API_KEY=

# ------------------------------------------------------------------------------
# Alerts - Discord
# ------------------------------------------------------------------------------
# Discord webhook URL for lead notifications and error alerts.
# [OPTIONAL]
DISCORD_WEBHOOK_URL=

# Channel-specific webhooks.
# DISCORD_NEW_LEADS_WEBHOOK=
# DISCORD_ERRORS_WEBHOOK=

# ------------------------------------------------------------------------------
# Alerts - Telegram
# ------------------------------------------------------------------------------
# Telegram bot token and chat ID for notifications.
# [OPTIONAL]
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Channel-specific chat IDs.
# TELEGRAM_NEW_LEADS_CHAT=
# TELEGRAM_ERRORS_CHAT=

# ------------------------------------------------------------------------------
# Ledger - AITable
# ------------------------------------------------------------------------------
# AITable credentials for event ledger persistence.
# [OPTIONAL]
AITABLE_API_TOKEN=
AITABLE_DATASHEET_ID=

# Set to "false" to disable AITable persistence and use in-memory/PostgreSQL only.
# LEAD_OS_USE_AITABLE_PERSISTENCE=true

# ------------------------------------------------------------------------------
# Intelligence - AgenticFlow
# ------------------------------------------------------------------------------
# [OPTIONAL]
# AGENTICFLOW_API_KEY=

# ------------------------------------------------------------------------------
# Automation Fallbacks
# ------------------------------------------------------------------------------
# Activepieces webhook for fallback automation.
# ACTIVEPIECES_WEBHOOK_URL=

# ElectroNeek webhook/API for RPA fallback.
# ELECTRONEEK_WEBHOOK_URL=
# ELECTRONEEK_API_KEY=

# Boost.space API key for alternative orchestration.
# BOOST_SPACE_API_KEY=
# BOOST_SPACE_MAKE_TOKEN=

# ------------------------------------------------------------------------------
# Operator Authentication
# ------------------------------------------------------------------------------
# Comma-separated list of email addresses allowed to access operator endpoints.
# The support email is included automatically.
# [RECOMMENDED]
LEAD_OS_OPERATOR_EMAILS=admin@example.com

# Secret used to sign operator session tokens and magic links.
# If unset, falls back to CRON_SECRET.
# [RECOMMENDED]
LEAD_OS_AUTH_SECRET=change-me-to-a-random-string

# ------------------------------------------------------------------------------
# Cron Authentication
# ------------------------------------------------------------------------------
# Secret for authenticating cron job requests (nurture endpoint).
# Sent as Bearer token in the Authorization header.
# [RECOMMENDED]
CRON_SECRET=change-me-to-a-random-string

# ------------------------------------------------------------------------------
# Safety Controls
# ------------------------------------------------------------------------------
# Set to "true" to enable live sends to external providers (email, SMS, WhatsApp, etc.).
# When "false" (default), all provider calls run in dry-run mode and log what would happen.
# [REQUIRED for production]
LEAD_OS_ENABLE_LIVE_SENDS=false

# Set to "true" to enable the data reset endpoint. Keep "false" in production.
# [OPTIONAL] Default: false
LEAD_OS_ALLOW_RESET=false
