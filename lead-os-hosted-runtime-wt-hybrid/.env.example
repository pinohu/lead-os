# Redis (BullMQ pricing queues)
REDIS_URL=

# Supabase (optional REST mirror for pricing_sku — same schema as Postgres migrations)
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Autonomous pricing
PRICING_TICK_INTERVAL_MS=60000
PRICING_MEASUREMENT_DELAY_MS=3600000
PRICING_MAX_ABS_CHANGE_PCT=0.05
PRICING_MIN_CHANGE_INTERVAL_MS=3600000
PRICING_FLOOR_OF_BASE_PCT=0.5
PRICING_CEIL_OF_BASE_PCT=2.0
PRICING_KILL_SWITCH=false
LEAD_OS_PRICING_WORKER_DISABLED=false
LEAD_OS_PRICING_ENABLE_SCHEDULER=true
SYSTEM_ENABLED=true
ENABLE_LIVE_PRICING=false
SUPABASE_KEY=

# Billing / SaaS gates (migration 007). When true, pricing ticks require an active subscription row.
LEAD_OS_BILLING_ENFORCE=false

# Cached billing gate TTL for middleware (ms).
LEAD_OS_BILLING_CACHE_TTL_MS=60000

# Single-tenant: reject API identities whose tenant ≠ LEAD_OS_TENANT_ID (default on).
LEAD_OS_SINGLE_TENANT_ENFORCE=true

# Public allowlisted /api routes — max requests per IP per minute (middleware).
LEAD_OS_PUBLIC_API_RATE_LIMIT=180

# Deep health: emit alert + pricingLog when persisted DLQ rows exceed threshold (0 = off).
LEAD_OS_DLQ_ALERT_THRESHOLD=0

# Deep health: emit alert when BullMQ waiting jobs exceed threshold (0 = off).
LEAD_OS_QUEUE_WAITING_ALERT_THRESHOLD=0

# Injected at image build; also written to public/build-id.json by prebuild when git available.
LEAD_OS_BUILD_ID=

# Worker process only: allow in-memory pricing fallback without Redis (development only).
LEAD_OS_WORKER_ALLOW_MEMORY=false
