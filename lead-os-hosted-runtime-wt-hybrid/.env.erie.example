# Erie.pro local directory demo — copy to .env.local and adjust.
# Use with: LEAD_OS_TENANT_ID=erie and migrations through 010 applied.

LEAD_OS_TENANT_ID=erie
LEAD_OS_SINGLE_TENANT_ENFORCE=true
LEAD_OS_DIRECTORY_TENANTS=erie
LEAD_OS_BILLING_ENFORCE=true
LEAD_OS_ENABLE_LIVE_SENDS=false

NEXT_PUBLIC_BRAND_NAME=Erie.pro
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_EMAIL=hello@erie.pro

LEAD_OS_AUTH_SECRET=replace-with-a-long-random-secret
CRON_SECRET=replace-cron-secret

LEAD_OS_DATABASE_URL=postgresql://lead_os:lead_os_dev_password@localhost:5432/lead_os
DATABASE_URL=postgresql://lead_os:lead_os_dev_password@localhost:5432/lead_os

# Optional AppSumo-style integrations (leave blank for simulated delivery only)
SUITEDASH_PUBLIC_ID=
SUITEDASH_SECRET_KEY=
ACTIVEPIECES_WEBHOOK_URL=
LEAD_OS_AUTOMATION_WEBHOOK_URL=
PABBLY_WEBHOOK_URL=

REDIS_URL=redis://localhost:6379
