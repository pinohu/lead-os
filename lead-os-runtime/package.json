{
  "name": "lead-os-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "lead-os": "./src/cli/index.ts",
    "lead-os-mcp": "./src/mcp/index.ts"
  },
  "scripts": {
    "dev": "next dev",
    "worker": "node --experimental-strip-types src/runtime/worker-entry.ts",
    "worker:pricing": "node --experimental-strip-types src/runtime/worker-entry.ts",
    "prebuild": "node scripts/write-build-id.mjs",
    "build": "next build",
    "start": "next start",
    "cli": "node --experimental-strip-types src/cli/index.ts",
    "mcp": "node --experimental-strip-types src/mcp/index.ts",
    "test": "cross-env LEAD_OS_USE_AITABLE_PERSISTENCE=false LEAD_OS_ENABLE_LIVE_SENDS=false node --test --test-concurrency=1 --experimental-test-isolation=none --experimental-strip-types tests/**/*.test.ts",
    "test:ci": "cross-env LEAD_OS_USE_AITABLE_PERSISTENCE=false LEAD_OS_ENABLE_LIVE_SENDS=false node --test --test-concurrency=1 --experimental-test-isolation=none --experimental-strip-types tests/**/*.test.ts",
    "verify:migrations": "node scripts/verify-migrations.mjs",
    "enumerate:api-routes": "node scripts/enumerate-api-routes.mjs",
    "enumerate:mutation-routes": "node scripts/enumerate-mutation-routes.mjs",
    "verify:backup-archive": "node scripts/verify-backup-archive.mjs",
    "detect:env": "node scripts/detect-env-presence.mjs",
    "gtm:print": "node --experimental-strip-types scripts/gtm-print.ts --"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.86.0",
    "autoprefixer": "^10.4.27",
    "bullmq": "^5.71.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "ioredis": "^5.9.1",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.7.0",
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "postcss": "^8.5.8",
    "react": "^19.1.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.72.0",
    "react-resizable-panels": "^4.8.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "stripe": "^21.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "cross-env": "^7.0.3",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pinohu/lead-os.git"
  },
  "license": "MIT",
  "homepage": "https://github.com/pinohu/lead-os#readme",
  "bugs": {
    "url": "https://github.com/pinohu/lead-os/issues"
  }
}
