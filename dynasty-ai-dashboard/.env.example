# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-random-32-byte-string

# Allowed emails (comma-separated)
ALLOWED_EMAILS=admin@example.com

# Default admin password (bcrypt hash of "changeme")
# Generate a new hash: node -e "require('bcryptjs').hash('yourpassword',10).then(h=>console.log(h))"
ADMIN_PASSWORD_HASH=$2a$10$placeholder-generate-a-real-hash-here

# Service URLs (relay for backend data)
API_RELAY_URL=http://localhost:9001

# Service health check URLs (comma-separated name:url pairs)
SERVICE_ENDPOINTS=Langfuse:http://localhost:3001,n8n:http://localhost:5678,Ollama:http://localhost:11434,Qdrant:http://qdrant.local:6333,Chroma:http://chroma.local:8000,SearXNG:http://searxng.local,AnythingLLM:http://anythingllm.local,ClawdbotGateway:http://localhost:18789

# Optional: Analytics
# NEXT_PUBLIC_ANALYTICS_ID=

# Optional: Feature Flags
# NEXT_PUBLIC_ENABLE_STREAMING=true
