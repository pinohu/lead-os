# Authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-random-32-byte-string

# Per-user auth (preferred): comma-separated email:bcrypt_hash pairs
# Generate hash: node -e "require('bcryptjs').hash('password',10).then(h=>console.log(h))"
# ALLOWED_USERS=admin@example.com:$2a$10$...,user2@example.com:$2a$10$...

# Shared-password auth (fallback): all users share one password
ALLOWED_EMAILS=admin@example.com
ADMIN_PASSWORD_HASH=$2a$10$placeholder-generate-a-real-hash-here

# Service URLs (relay for backend data)
API_RELAY_URL=http://localhost:9001

# Service health check URLs (comma-separated Name:URL pairs)
SERVICE_ENDPOINTS=Langfuse:http://localhost:3001,n8n:http://localhost:5678,Ollama:http://localhost:11434

# Knowledge base path (defaults to ~/clawd)
# KNOWLEDGE_BASE_PATH=/path/to/clawd

# Settings persistence directory (defaults to .data/)
# SETTINGS_DIR=/path/to/data
