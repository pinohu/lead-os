# ─────────────────────────────────────────────────────────────
# Kwode Video Factory — environment variables
# Copy to .env and edit. Do not commit secrets.
# ─────────────────────────────────────────────────────────────

NODE_ENV=development
APP_BASE_URL=http://localhost:3000
API_PORT=3000

# ── Database (Docker Compose default) ────────────────────────
DATABASE_URL=postgresql://kwode:kwode@db:5432/kwode_video?schema=public
REDIS_URL=redis://redis:6379

# ── LLM providers ────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LOCAL_LLM_BASE_URL=

# ── Hermes agent runtime ─────────────────────────────────────
HERMES_ENABLED=false
HERMES_COMMAND=hermes
HERMES_WORKSPACE_PATH=
HERMES_AGENT_CONFIG_PATH=
HERMES_GATEWAY_ENABLED=false

# ── ViMax video planning runtime ─────────────────────────────
VIMAX_ENABLED=false
VIMAX_COMMAND=
VIMAX_WORKSPACE_PATH=
VIMAX_OUTPUT_PATH=

# ── ComfyUI image/video runtime ──────────────────────────────
COMFYUI_ENABLED=false
COMFYUI_BASE_URL=

# ── Storage ──────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ── CRM / Client portal ──────────────────────────────────────
SUITEDASH_ENABLED=false
SUITEDASH_API_KEY=

# ── Billing ──────────────────────────────────────────────────
THRIVECART_ENABLED=false
THRIVECART_WEBHOOK_SECRET=

# ── Content delivery / membership ────────────────────────────
PRODUCTDYNO_ENABLED=false
PRODUCTDYNO_API_KEY=

# ── Video hosting ────────────────────────────────────────────
GUMLET_ENABLED=false
GUMLET_API_KEY=

PUBLITIO_ENABLED=false
PUBLITIO_API_KEY=
PUBLITIO_API_SECRET=

# ── Erie.pro (directory + provider growth) ───────────────────
ERIE_PRO_ENABLED=false
ERIE_PRO_API_BASE_URL=
ERIE_PRO_API_KEY=

# ── YourDeputy (productization) ──────────────────────────────
YOURDEPUTY_ENABLED=false
YOURDEPUTY_API_BASE_URL=
YOURDEPUTY_API_KEY=

# ── Global safety flags (default OFF) ────────────────────────
# These three flags govern destructive/irreversible behavior.
# Leave OFF in MVP unless explicitly authorized.
SAFE_PUBLIC_PUBLISHING_ENABLED=false
SAFE_LIVE_BILLING_ENABLED=false
SAFE_OUTREACH_ENABLED=false
