// ── Service Request Action / Notification / Status (P0) ─────────────
// Separate from Lead: tracks consumer-visible lifecycle, notification
// events, and honest delivery status. Links to Lead via leadId when routed.

enum ServiceRequestStatus {
  draft
  submitted
  consumer_confirmation_queued
  consumer_confirmation_sent
  consumer_confirmation_failed
  provider_notification_queued
  provider_notification_sent
  provider_notification_failed
  completed
  cancelled
}

enum NotificationEventStatus {
  queued
  sending
  sent
  failed
}

enum NotificationRecipientRole {
  consumer
  provider
  admin
}

model UserAction {
  id                String   @id @default(cuid())
  correlationId     String
  actionType        String
  actorType         String   @default("consumer")
  actorId           String?
  serviceRequestId  String?
  serviceRequest    ServiceRequest? @relation(fields: [serviceRequestId], references: [id], onDelete: SetNull)
  metadata          Json?    @default("{}")
  createdAt         DateTime @default(now())

  @@index([correlationId])
  @@index([serviceRequestId])
  @@index([actionType, createdAt])
  @@map("user_actions")
}

model ServiceRequest {
  id                      String               @id @default(cuid())
  requestId               String               @unique
  correlationId           String               @unique
  status                  ServiceRequestStatus @default(submitted)
  statusAccessToken       String               @unique
  leadId                  String?

  niche                   String
  city                    String               @default("erie")
  firstName               String?
  lastName                String?
  email                   String
  phone                   String?
  message                 String?
  sourcePage              String?
  routingIntent           String               @default("general")
  requestedProviderName   String?
  requestedProviderSlug   String?
  requestedProviderPhone  String?
  requestedProviderAddress String?
  routedToProviderId      String?
  routedToProviderName    String?
  routeType               String?

  tcpaConsent             Boolean              @default(false)
  tcpaConsentText         String?
  tcpaConsentAt           DateTime?
  tcpaIpAddress           String?

  metadata                Json?                @default("{}")

  userActions             UserAction[]
  notificationEvents      NotificationEvent[]
  statusEvents            StatusEvent[]

  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  @@index([email])
  @@index([status])
  @@index([correlationId])
  @@index([leadId])
  @@map("service_requests")
}

model NotificationTemplate {
  id          String   @id @default(cuid())
  slug        String   @unique
  subject     String
  htmlBody    String
  textBody    String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events      NotificationEvent[]

  @@map("notification_templates")
}

model NotificationEvent {
  id                String                    @id @default(cuid())
  serviceRequestId  String
  serviceRequest    ServiceRequest            @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  templateSlug      String
  template          NotificationTemplate      @relation(fields: [templateSlug], references: [slug], onDelete: Restrict)
  recipientEmail    String
  recipientRole     NotificationRecipientRole
  status            NotificationEventStatus   @default(queued)
  retryCount        Int                       @default(0)
  maxRetries        Int                       @default(3)
  nextRetryAt       DateTime?
  lastError         String?
  providerMessageId String?
  sentAt            DateTime?
  metadata          Json?                     @default("{}")
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([serviceRequestId])
  @@index([status, nextRetryAt])
  @@index([templateSlug])
  @@map("notification_events")
}

model StatusEvent {
  id               String               @id @default(cuid())
  serviceRequestId String
  serviceRequest   ServiceRequest       @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  status           ServiceRequestStatus
  message          String?
  metadata         Json?                @default("{}")
  createdAt        DateTime             @default(now())

  @@index([serviceRequestId, createdAt])
  @@map("status_events")
}

// ── Persona-locked chatbot ───────────────────────────────────────────

enum ChatPersona {
  consumer_service
  consumer_status
  provider_growth
  provider_operations
  admin_operations
}

enum ChatSessionStatus {
  active
  closed
  escalated
}

enum ChatMessageRole {
  user
  assistant
  system
  tool
}

enum ChatActionStatus {
  pending
  completed
  failed
}

enum ChatEscalationStatus {
  open
  in_progress
  resolved
}

model ChatSession {
  id                String            @id @default(cuid())
  persona           ChatPersona
  status            ChatSessionStatus @default(active)
  visitorId         String?
  userId            String?
  providerId        String?
  serviceRequestId  String?
  contextPath       String?
  contextJson       Json?             @default("{}")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  messages     ChatMessage[]
  actions      ChatAction[]
  escalations  ChatEscalation[]

  @@index([persona, status])
  @@index([visitorId])
  @@index([serviceRequestId])
  @@map("chat_sessions")
}

model ChatMessage {
  id          String          @id @default(cuid())
  sessionId   String
  session     ChatSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role        ChatMessageRole
  content     String
  toolName    String?
  toolPayload Json?
  createdAt   DateTime        @default(now())

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

model ChatAction {
  id         String           @id @default(cuid())
  sessionId  String
  session    ChatSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  toolName   String
  input      Json             @default("{}")
  output     Json?
  status     ChatActionStatus @default(pending)
  error      String?
  createdAt  DateTime         @default(now())

  @@index([sessionId, createdAt])
  @@index([toolName, status])
  @@map("chat_actions")
}

model ChatEscalation {
  id         String               @id @default(cuid())
  sessionId  String
  session    ChatSession          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  reason     String
  status     ChatEscalationStatus @default(open)
  metadata   Json?                @default("{}")
  createdAt  DateTime             @default(now())
  resolvedAt DateTime?

  @@index([sessionId])
  @@index([status, createdAt])
  @@map("chat_escalations")
}

// ── Intake Widget Conversations ─────────────────────────────────────
// Conversational intake (AI-led) sessions. One row per conversation.
// Conversations that finish successfully create a Lead row and store the
// resulting leadId. Conversations that are abandoned stay here for
// funnel analysis and are cleaned up by the cleanup cron after 30 days.

model IntakeConversation {
  id                      String   @id @default(cuid())
  citySlug                String   @default("erie")
  startedFromNicheSlug    String?
  currentStep             String   @default("problem") // problem | location | urgency | budget | contact | complete
  /** Full ordered list of {role, content, meta, at} messages */
  messages                Json     @default("[]")
  /** Partial then complete IntakeOutcome */
  outcome                 Json     @default("{}")
  /** A/B variant served. Either "intake" (this widget) or "form" (legacy fallback) */
  variant                 String   @default("intake")
  /** Stamp how the conversation ended */
  outcomeStatus           String   @default("in_progress") // in_progress | completed | abandoned | error
  /** Once a Lead is created from this conversation, link to it */
  leadId                  String?  @unique
  /** Visitor IP for rate-limiting and abuse mitigation (truncated) */
  ipPrefix                String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([citySlug, currentStep])
  @@index([outcomeStatus, updatedAt])
  @@index([startedFromNicheSlug])
  @@map("intake_conversations")
}

// ── A/B Testing Experiments ──────────────────────────────────────────
// Track exposures (visitor saw a variant) and conversions (visitor
// completed the experiment's success event). Experiment definitions
// live in code (src/lib/experiments/registry.ts), so these tables
// only store the runtime data.

model ExperimentExposure {
  id            String   @id @default(cuid())
  visitorId     String   // stable cookie-derived visitor identifier
  experimentKey String
  variantKey    String
  nicheSlug     String?
  exposedAt     DateTime @default(now())

  // Idempotency: a visitor should appear at most once per experiment.
  // The runtime layer is responsible for upserting on (visitorId, experimentKey).
  @@unique([visitorId, experimentKey])
  @@index([experimentKey, exposedAt])
  @@index([visitorId])
  @@map("experiment_exposures")
}

model ExperimentConversion {
  id            String   @id @default(cuid())
  visitorId     String
  experimentKey String
  /** True when the visitor was already exposed to a variant before converting */
  exposedFirst  Boolean  @default(false)
  /** Optional payload — revenue, leadId, etc. */
  payload       Json?
  convertedAt   DateTime @default(now())

  @@index([experimentKey, convertedAt])
  @@index([visitorId])
  @@map("experiment_conversions")
}
