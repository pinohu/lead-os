// ── Erie Pro — Prisma Schema ────────────────────────────────────────
// Replaces all 7 in-memory JavaScript Map stores with persistent tables.
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ──────────────────────────────────────────────────────────

enum ProviderTier {
  primary
  backup
  overflow
}

enum SubscriptionStatus {
  active
  trial
  past_due
  expired
  cancelled
}

enum LeadRouteType {
  primary
  failover
  overflow
  unmatched
}

enum LeadOutcomeType {
  responded
  converted
  no_response
  declined
  cancelled
}

enum LeadTemperature {
  cold
  warm
  hot
  burning
}

enum NotificationType {
  new_lead
  sla_warning
  lead_expired
  review_received
  payment_failed
  subscription_activated
  subscription_cancelled
}

enum NotificationChannel {
  email
  sms
  both
}

enum DeliveryStatus {
  pending
  sent
  delivered
  failed
}

enum CallOutcome {
  connected
  voicemail
  missed
  busy
}

enum CheckoutSessionType {
  territory_claim
  lead_purchase
  concierge_job
  annual_membership
}

enum CheckoutSessionStatus {
  pending
  completed
  expired
  cancelled
}

enum DisputeStatus {
  pending
  approved
  denied
}

enum VerificationStatus {
  unverified // Just claimed, no verification attempted
  pending // Verification code sent, awaiting entry
  verified // Ownership confirmed
  auto_verified // Email domain matched listing website
  admin_approved // Manually approved by admin
  rejected // Admin rejected claim
}

enum OfferFulfillmentType {
  scorecard
  blueprint
  template_kit
  campaign_kit
  automation_kit
  subscription_report
  website_blueprint
}

enum OfferStatus {
  active
  paused
  archived
}

enum OfferPurchaseStatus {
  pending
  paid
  fulfilled
  failed
  refunded
  cancelled
}

enum FulfillmentJobStatus {
  pending
  generating
  fulfilled
  emailed
  synced
  failed
  cancelled
}

enum GeneratedAssetType {
  html_report
  pdf_blueprint
  template_pack
  checklist
  dashboard_link
}

enum ProviderLifecycleStatus {
  pending_payment
  paid_pending_onboarding
  provisioning
  live
  failed
  suspended
  cancelled
}

enum ProvisioningJobStatus {
  pending
  running
  completed
  failed
  cancelled
}

enum MicrositeStatus {
  draft
  provisioning
  live
  suspended
  archived
}

enum ProviderInterestStatus {
  new
  contacted
  qualified
  converted
  archived
}

enum ClaimRequestStatus {
  pending
  approved
  rejected
  expired
}

enum ProviderEligibilityTier {
  paid_unverified
  data_pending
  eligible_draft
  eligible_live
  suspended_trust
  admin_hold
}

enum MicrositePublishMode {
  draft
  review_required
  auto_eligible
}

enum ThriveCartReconciliationStatus {
  pending
  matched
  unmatched
  manual_resolved
  ignored
}

// ── Provider ───────────────────────────────────────────────────────

model Provider {
  id              String   @id @default(cuid())
  slug            String   @unique
  businessName    String
  niche           String
  city            String   @default("erie")
  phone           String
  email           String
  website         String?
  addressStreet   String?
  addressCity     String?
  addressState    String?
  addressZip      String?
  serviceAreas    String[] @default([])
  description     String   @default("")
  yearEstablished Int?
  employeeCount   String?
  license         String?
  insurance       Boolean  @default(false)

  // Subscription & billing
  tier                 ProviderTier       @default(primary)
  subscriptionStatus   SubscriptionStatus @default(trial)
  monthlyFee           Float              @default(400)
  billingInterval      String             @default("monthly") // "monthly" | "annual"
  stripeCustomerId     String?
  stripeSubscriptionId String?
  emailVerified        Boolean            @default(false)
  emailVerifyToken     String?
  passwordHash         String?
  tosAcceptedAt        DateTime?
  gracePeriodEndsAt    DateTime?
  notificationPrefs    Json?              @default("{}")

  // Ownership verification (claim anti-fraud)
  verificationStatus   VerificationStatus @default(unverified)
  verificationCode     String? // 6-digit code
  verificationCodeExp  DateTime? // Code expiry (15 min)
  verificationAttempts Int                @default(0) // Code-entry brute-force protection
  claimedListingId     String? // DirectoryListing.id being claimed

  // Local Authority Microsite commercial OS (payment ≠ trust)
  lifecycleStatus      ProviderLifecycleStatus @default(pending_payment)
  eligibilityTier      ProviderEligibilityTier @default(paid_unverified)
  thriveCartCustomerId String?

  // SLA tracking
  slaViolationCount Int     @default(0)
  businessHours     Json?
  timezone          String  @default("America/New_York")
  photoUrl          String?
  coverPhotoUrl     String?

  // Performance metrics (denormalized for fast reads)
  totalLeads      Int   @default(0)
  convertedLeads  Int   @default(0)
  avgResponseTime Float @default(0) // seconds
  avgRating       Float @default(0) // 0-5
  reviewCount     Int   @default(0)

  // Timestamps
  claimedAt  DateTime  @default(now())
  lastLeadAt DateTime?
  churnedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Relations
  territories      Territory[]
  leads            Lead[]            @relation("RoutedLeads")
  leadOutcomes     LeadOutcome[]
  notifications    Notification[]
  trackedCalls     TrackedCall[]
  disputes         LeadDispute[]
  auditLogs        AuditLog[]
  checkoutSessions CheckoutSession[]
  apiKeys              ApiKey[]
  webhookEndpoints     WebhookEndpoint[]
  providerSubscription ProviderSubscription?
  microsites           Microsite[]
  provisioningJobs     ProvisioningJob[]
  providerLeads        ProviderLead[]
  providerTasks        ProviderTask[]
  claimRequests        ClaimRequest[]
  providerOrderItems   ProviderOrderItem[]

  @@index([niche, city])
  @@index([lifecycleStatus])
  @@index([eligibilityTier])
  @@index([niche, subscriptionStatus])
  @@index([email])
  @@index([stripeCustomerId])
  @@map("providers")
}

// ── Lead ───────────────────────────────────────────────────────────

model Lead {
  id          String          @id @default(cuid())
  niche       String
  city        String          @default("erie")
  firstName   String?
  lastName    String?
  email       String
  phone       String?
  message     String?
  routeType   LeadRouteType   @default(unmatched)
  temperature LeadTemperature @default(warm)
  slaDeadline DateTime?
  statusToken String?         @unique
  source      String          @default("erie-pro")
  deliverAt   DateTime?

  // Provider-specific capture and delayed delivery
  requestedProviderName    String?
  requestedProviderSlug    String?
  requestedProviderPhone   String?
  requestedProviderAddress String?
  sourcePage               String?
  routingIntent            String?   @default("general")
  providerDeliveryStatus   String    @default("not_applicable") // not_applicable | pending_provider_delivery | delivered | failed | cancelled
  providerDeliveredAt      DateTime?
  providerDeliveredBy      String?
  providerDeliveryNotes    String?

  // External sync tracking (Boost.space, SuiteDash, etc.)
  boostspaceSyncStatus String    @default("not_configured") // not_configured | pending | synced | failed
  boostspaceSyncedAt   DateTime?
  boostspaceLastError  String?
  suitedashSyncStatus  String    @default("not_configured")
  suitedashRecordId    String?
  externalSyncPayload  Json?

  // TCPA compliance fields
  tcpaConsent     Boolean   @default(false)
  tcpaConsentText String?
  tcpaConsentAt   DateTime?
  tcpaIpAddress   String?

  // Routing
  routedToId String?
  routedTo   Provider? @relation("RoutedLeads", fields: [routedToId], references: [id], onDelete: SetNull)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  outcomes LeadOutcome[]
  disputes LeadDispute[]

  @@index([niche, city])
  @@index([routedToId])
  @@index([routeType, niche])
  @@index([requestedProviderSlug])
  @@index([providerDeliveryStatus])
  @@map("leads")
}

// ── Universal Lead / Phone / Call Event Ledger ─────────────────────

model LeadEvent {
  id             String  @id @default(cuid())
  eventType      String
  sourceSystem   String  @default("erie-pro")
  sourceDomain   String  @default("erie.pro")
  sourcePage     String?
  sourcePageType String?
  serviceNiche   String?
  serviceSlug    String?
  city           String  @default("erie")
  keywordCluster String?
  intentType     String?
  urgency        String  @default("standard")

  // Event identity and call attribution
  externalEventId     String?
  callId              String?
  phoneNumberClicked  String?
  trackingNumber      String?
  dialedNumber        String?
  callerPhone         String?
  callDurationSeconds Int?
  callOutcome         String?
  transferStatus      String?
  recordingUrl        String?
  transcriptUrl       String?

  // Extracted consumer/provider intent
  consumerName           String?
  consumerPhone          String?
  consumerEmail          String?
  requestSummary         String?
  requestedProviderName  String?
  requestedProviderSlug  String?
  exclusiveProviderId    String?
  exclusiveProviderName  String?
  routingModel           String?
  providerDeliveryStatus String  @default("not_applicable")
  manualReviewRequired   Boolean @default(false)

  // Consent and payload preservation
  consentToContact  Boolean @default(false)
  marketingConsent  Boolean @default(false)
  rawPayload        Json?
  normalizedPayload Json?

  // External sync tracking
  boostspaceSyncStatus String    @default("not_configured")
  boostspaceSyncedAt   DateTime?
  boostspaceLastError  String?
  suitedashSyncStatus  String    @default("not_configured")
  suitedashRecordId    String?

  // Optional link to a full lead row when the event becomes one
  leadId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventType])
  @@index([sourceSystem])
  @@index([serviceNiche, city])
  @@index([requestedProviderSlug])
  @@index([exclusiveProviderId])
  @@index([providerDeliveryStatus])
  @@index([boostspaceSyncStatus])
  @@index([callId])
  @@index([externalEventId])
  @@index([leadId])
  @@map("lead_events")
}

// ── Lead Outcome ───────────────────────────────────────────────────

model LeadOutcome {
  id                  String          @id @default(cuid())
  leadId              String
  lead                Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  providerId          String
  provider            Provider        @relation(fields: [providerId], references: [id], onDelete: Cascade)
  outcome             LeadOutcomeType
  responseTimeSeconds Float?
  satisfactionRating  Float? // 0-5
  createdAt           DateTime        @default(now())

  @@index([leadId])
  @@index([providerId])
  @@map("lead_outcomes")
}

// ── Territory ──────────────────────────────────────────────────────

model Territory {
  id            String       @id @default(cuid())
  niche         String
  city          String       @default("erie")
  providerId    String
  provider      Provider     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  tier          ProviderTier @default(primary)
  activatedAt   DateTime     @default(now())
  deactivatedAt DateTime?
  isPaused      Boolean      @default(false)
  pausedAt      DateTime?

  @@unique([niche, city]) // Enforces exclusive territory at DB level
  @@index([providerId])
  @@map("territories")
}

// ── Notification ───────────────────────────────────────────────────

model Notification {
  id             String              @id @default(cuid())
  type           NotificationType
  providerId     String
  provider       Provider            @relation(fields: [providerId], references: [id], onDelete: Cascade)
  channel        NotificationChannel @default(email)
  message        String
  deliveryStatus DeliveryStatus      @default(pending)
  sentAt         DateTime            @default(now())
  createdAt      DateTime            @default(now())

  @@index([providerId])
  @@index([type])
  @@map("notifications")
}

// ── Tracked Call ───────────────────────────────────────────────────

model TrackedCall {
  id             String      @id @default(cuid())
  niche          String
  city           String      @default("erie")
  callerPhone    String
  trackingNumber String
  routedTo       String // provider phone number
  providerId     String?
  provider       Provider?   @relation(fields: [providerId], references: [id], onDelete: SetNull)
  duration       Int         @default(0) // seconds
  recordingUrl   String?
  outcome        CallOutcome @default(missed)
  createdAt      DateTime    @default(now())

  @@index([niche, city])
  @@index([providerId])
  @@map("tracked_calls")
}

// ── Checkout Session ───────────────────────────────────────────────

model CheckoutSession {
  id              String                @id @default(cuid())
  sessionType     CheckoutSessionType
  stripeSessionId String?               @unique
  niche           String
  city            String                @default("erie")
  providerEmail   String
  providerName    String?
  providerId      String?
  provider        Provider?             @relation(fields: [providerId], references: [id], onDelete: SetNull)
  monthlyFee      Float?
  status          CheckoutSessionStatus @default(pending)

  // For lead purchases
  leadId      String?
  temperature LeadTemperature?
  price       Float?

  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  completedAt DateTime?

  // ── Concierge ops fields ──────────────────────────────────────
  // Populated by the ops team on /admin/concierge. Tracks who the
  // job was assigned to, private notes, and when the job was
  // actually delivered to the requester.
  assignedProviderId String?
  opsNotes           String?
  fulfilledAt        DateTime?

  // ── Annual membership renewal lifecycle ────────────────────────
  // For sessionType="annual_membership". The cron writes these as
  // it sends 30-day / 7-day reminders, and marks the membership
  // expired at term end.
  renewalReminder30SentAt DateTime?
  renewalReminder7SentAt  DateTime?
  expiredAt               DateTime?

  @@index([stripeSessionId])
  @@index([providerEmail])
  @@index([sessionType, status])
  @@map("checkout_sessions")
}

// ── Lead Dispute ───────────────────────────────────────────────────

model LeadDispute {
  id           String        @id @default(cuid())
  leadId       String
  lead         Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  providerId   String
  provider     Provider      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  reason       String // "wrong_number" | "spam" | "out_of_area" | "duplicate" | "other"
  description  String?
  status       DisputeStatus @default(pending)
  creditAmount Float?
  resolvedAt   DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([leadId])
  @@index([providerId])
  @@map("lead_disputes")
}

// ── Runtime Settings (key/value store) ──────────────────────────────
// Generic setting store for ops-controlled runtime config that must
// live outside env vars (e.g. founding-seat claimed count, current
// launch-kit notes). Values are JSON-serialized strings so we can
// put numbers, flags, or small objects behind the same interface.

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String // JSON-serialized
  updatedAt DateTime @updatedAt
  updatedBy String? // email of admin who last touched it
  createdAt DateTime @default(now())

  @@index([key])
  @@map("settings")
}

// ── Audit Log ──────────────────────────────────────────────────────

model AuditLog {
  id         String    @id @default(cuid())
  action     String // "territory.claimed", "provider.login", "subscription.changed", etc.
  entityType String // "provider", "lead", "territory", etc.
  entityId   String?
  providerId String?
  provider   Provider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  metadata   Json? // Arbitrary context data
  ipAddress  String?
  createdAt  DateTime  @default(now())

  @@index([action])
  @@index([providerId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ── Auth (NextAuth v5) ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("provider") // "provider" | "admin"
  providerId    String? // Links user to their provider profile

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Rate Limit ─────────────────────────────────────────────────────
// Sliding-window rate limiting using Postgres instead of external Redis.

model RateLimitEntry {
  id        String   @id @default(cuid())
  key       String // e.g., "lead:192.168.1.1"
  createdAt DateTime @default(now())

  @@index([key, createdAt])
  @@map("rate_limit_entries")
}

// ── Contact Message ────────────────────────────────────────────────
// Phase 1.5.11: Contact form must actually store messages

model ContactMessage {
  id        String   @id @default(cuid())
  name      String?
  email     String
  phone     String?
  message   String?
  niche     String?
  status    String   @default("unread") // "unread" | "read" | "replied"
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

// ── Directory Listing ─────────────────────────────────────────────
// Scraped Google Places data for the "Build First, Sell Later" model.
// Many listings per niche (unlike Territory which is 1:1).
// When a business claims their listing, claimedByProviderId links them.

model DirectoryListing {
  id                  String    @id @default(cuid())
  slug                String    @unique
  googlePlaceId       String?   @unique
  businessName        String
  niche               String
  phone               String?
  email               String?
  website             String?
  googleBusinessUrl   String?
  addressStreet       String?
  addressCity         String?
  addressState        String?
  addressZip          String?
  addressFormatted    String?
  latitude            Float?
  longitude           Float?
  description         String?
  rating              Float?
  reviewCount         Int       @default(0)
  priceLevel          Int?
  hoursJson           Json?
  categories          String[]  @default([])
  photoRefs           String[]  @default([])
  reviewsJson         Json?
  servicesOffered     String[]  @default([])
  isActive            Boolean   @default(true)
  claimedByProviderId String?
  source              String    @default("google_places")
  lastScrapedAt       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([niche])
  @@index([niche, addressCity])
  @@index([slug])
  @@map("directory_listings")
}

// ── Suppression List (TCPA/CAN-SPAM compliance) ───────────────────

model Suppression {
  id        String   @id @default(cuid())
  email     String?
  phone     String?
  reason    String   @default("unsubscribe")
  createdAt DateTime @default(now())

  @@index([email])
  @@index([phone])
  @@map("suppressions")
}

// ── API Key ───────────────────────────────────────────────────────

model ApiKey {
  id          String    @id @default(cuid())
  keyHash     String    @unique
  label       String
  providerId  String
  provider    Provider  @relation(fields: [providerId], references: [id])
  permissions String[]  @default(["leads:write"])
  lastUsedAt  DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([keyHash])
  @@index([providerId])
  @@map("api_keys")
}

// ── Webhook Endpoint ──────────────────────────────────────────────

model WebhookEndpoint {
  id         String   @id @default(cuid())
  providerId String
  provider   Provider @relation(fields: [providerId], references: [id])
  url        String
  secret     String
  events     String[] @default(["lead.created", "lead.routed"])
  isActive   Boolean  @default(true)
  failCount  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([providerId])
  @@map("webhook_endpoints")
}

// Automated offer engine: ThriveCart/ConvertBox -> Neon -> fulfillment -> Boost/SuiteDash.

model Offer {
  id                String               @id @default(cuid())
  slug              String               @unique
  title             String
  shortTitle        String?
  description       String
  category          String
  fulfillmentType   OfferFulfillmentType
  status            OfferStatus          @default(active)
  basePriceCents    Int                  @default(0)
  currency          String               @default("USD")
  checkoutUrl       String?
  checkoutProductId String?
  repoSource        String?
  autoFulfillable   Boolean              @default(true)
  sortOrder         Int                  @default(100)
  metadata          Json?                @default("{}")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  variants      OfferVariant[]
  serviceMaps   ServiceOfferMap[]
  purchases     OfferPurchase[]
  interactions  OfferInteraction[]
  subscriptions OfferSubscriptionEntitlement[]

  @@index([status, category])
  @@index([checkoutProductId])
  @@map("offers")
}

model OfferVariant {
  id                String   @id @default(cuid())
  offerId           String
  offer             Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  serviceSlug       String?
  serviceFamily     String?
  headline          String
  subheadline       String
  painPoint         String
  promise           String
  primaryCta        String
  deliverySummary   String
  deliverableConfig Json?    @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([offerId, serviceSlug, serviceFamily])
  @@index([serviceSlug])
  @@index([serviceFamily])
  @@map("offer_variants")
}

model ServiceOfferMap {
  id                    String   @id @default(cuid())
  serviceSlug           String
  serviceLabel          String
  serviceFamily         String
  offerId               String
  offer                 Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  priority              Int      @default(100)
  visitorSegment        String   @default("provider")
  urgency               String   @default("standard")
  conversionAngle       String
  painPoint             String
  recommendedPriceCents Int?
  isPrimary             Boolean  @default(false)
  metadata              Json?    @default("{}")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([serviceSlug, offerId, visitorSegment])
  @@index([serviceSlug, priority])
  @@index([serviceFamily])
  @@index([offerId])
  @@map("service_offer_maps")
}

model OfferCustomer {
  id                String   @id @default(cuid())
  email             String   @unique
  firstName         String?
  lastName          String?
  fullName          String?
  phone             String?
  companyName       String?
  websiteUrl        String?
  googleBusinessUrl String?
  city              String   @default("erie")
  county            String   @default("Erie County")
  state             String   @default("PA")
  suitedashRecordId String?
  metadata          Json?    @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  purchases     OfferPurchase[]
  interactions  OfferInteraction[]
  subscriptions OfferSubscriptionEntitlement[]

  @@index([email])
  @@map("offer_customers")
}

model OfferPurchase {
  id                   String              @id @default(cuid())
  offerId              String
  offer                Offer               @relation(fields: [offerId], references: [id], onDelete: Restrict)
  customerId           String
  customer             OfferCustomer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  serviceSlug          String
  serviceLabel         String
  serviceFamily        String
  status               OfferPurchaseStatus @default(pending)
  amountCents          Int                 @default(0)
  currency             String              @default("USD")
  sourceSystem         String              @default("erie-pro")
  sourcePage           String?
  sourcePageType       String?
  convertBoxId         String?
  convertBoxEventId    String?
  thriveCartOrderId    String?
  thriveCartProductId  String?
  checkoutSessionId    String?
  coupon               String?
  affiliate            String?
  utmSource            String?
  utmMedium            String?
  utmCampaign          String?
  gclid                String?
  rawPayload           Json?               @default("{}")
  normalizedPayload    Json?               @default("{}")
  boostspaceSyncStatus String              @default("not_configured")
  boostspaceSyncedAt   DateTime?
  boostspaceLastError  String?
  suitedashSyncStatus  String              @default("not_configured")
  suitedashRecordId    String?
  emailDeliveryStatus  String              @default("pending")
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  paidAt               DateTime?
  fulfilledAt          DateTime?

  fulfillmentJobs FulfillmentJob[]
  generatedAssets GeneratedAsset[]
  subscriptions   OfferSubscriptionEntitlement[]

  // ── ThriveCart idempotency ─────────────────────────────────────
  // Defense-in-depth alongside ThriveCartEvent.payloadHash. Two
  // concurrent webhook deliveries could both pass the hash check
  // (race window between SELECT and INSERT). A compound unique on
  // (thriveCartOrderId, offerId) makes the second concurrent insert
  // fail at the DB level. NULL orderIds are allowed to coexist by
  // default Postgres unique semantics, so non-ThriveCart purchases
  // (Stripe checkouts, manual entries) are unaffected.
  @@unique([thriveCartOrderId, offerId])
  @@index([status, createdAt])
  @@index([serviceSlug])
  @@index([serviceFamily])
  @@index([thriveCartOrderId])
  @@index([customerId])
  @@map("offer_purchases")
}

