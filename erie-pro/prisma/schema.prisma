model ThriveCartEvent {
  id                String    @id @default(cuid())
  eventType         String
  orderId           String?
  productId         String?
  customerEmail     String?
  purchaseId        String?
  signatureValid    Boolean   @default(false)
  rawPayload        Json      @default("{}")
  normalizedPayload Json?     @default("{}")
  // ── Idempotency ────────────────────────────────────────────────
  // SHA-256 of the raw request body. ThriveCart retries the same
  // payload on delivery failures; this column lets the webhook handler
  // short-circuit on a duplicate before creating any purchase rows.
  // Nullable for backfill safety on existing rows.
  payloadHash       String?   @unique
  processedAt       DateTime?
  processingStatus      String                       @default("pending")
  reconciliationStatus ThriveCartReconciliationStatus @default(pending)
  providerSubscriptionId String?
  lastError             String?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  reconciliationItems ThriveCartReconciliationItem[]

  @@index([eventType])
  @@index([orderId])
  @@index([productId])
  @@index([customerEmail])
  @@index([processingStatus])
  @@index([reconciliationStatus])
  @@map("thrivecart_events")
}

