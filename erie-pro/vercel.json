{
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.erie.pro" }],
      "destination": "https://erie.pro/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "src/app/api/webhooks/stripe/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/**/*.ts": {
      "maxDuration": 10,
      "memory": 256
    }
  },
  "crons": [
    { "path": "/api/cron/sla-checker", "schedule": "*/15 * * * *" },
    { "path": "/api/cron/check-grace-periods", "schedule": "0 9 * * *" },
    { "path": "/api/cron/archive-stale-leads", "schedule": "0 3 * * *" },
    { "path": "/api/cron/cleanup", "schedule": "0 */6 * * *" },
    { "path": "/api/cron/process-deletions", "schedule": "0 2 * * *" }
  ]
}
