# ── Erie Pro Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Database (Vercel Postgres / Neon) ───────────────────────────────
# Pooled connection (for queries via Prisma)
DATABASE_URL="postgresql://user:password@host:5432/erie_pro?sslmode=require"
# Direct connection (for migrations only)
DIRECT_URL="postgresql://user:password@host:5432/erie_pro?sslmode=require"

# ── Stripe ──────────────────────────────────────────────────────────
# Leave blank for dry-run mode (no real payments)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ThriveCart checkout and event subscription integration
THRIVECART_WEBHOOK_SECRET=""
THRIVECART_WEBHOOK_TOKEN=""
THRIVECART_API_KEY=""
THRIVECART_ACCOUNT_SLUG="relgard"

# ── App URL ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3002"

# ── Auth (NextAuth v5) ─────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=""
AUTH_URL="http://localhost:3002"

# ── Upstash Redis (rate limiting) ─────────────────────────────────
# Falls back to in-memory when blank (dev only — not shared across serverless instances)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Email (Emailit + notification adapter) ───────────────────────
EMAILIT_API_KEY=""
# console | emailit | resend | sendgrid | postmark | mailgun | smtp
EMAIL_PROVIDER=""
EMAIL_FROM_NAME="Erie Pro"
EMAIL_FROM_ADDRESS=""
# Optional provider keys (when EMAIL_PROVIDER matches)
RESEND_API_KEY=""
SENDGRID_API_KEY=""
POSTMARK_SERVER_TOKEN=""
MAILGUN_API_KEY=""
MAILGUN_DOMAIN=""

# ── Admin ───────────────────────────────────────────────────────────
ADMIN_ACCESS_KEY=""
ADMIN_EMAIL=""
REVENUE_MONITORING_EMAIL=""
REVENUE_MONITORING_TOKEN=""
PRODUCTDYNO_API_KEY=""
PRODUCTDYNO_WEBHOOK_URL=""
PRODUCTDYNO_PRODUCT_MAP_JSON=""
DOCUMENT_DELIVERY_WEBHOOK_URL=""
DOCUMENT_DELIVERY_TOKEN=""
TASKADE_WEBHOOK_URL=""
TASKADE_API_KEY=""
# Set to "true" to enable the one-time /api/setup-admin endpoint
ALLOW_ADMIN_SETUP=""

# ── Cron ─────────────────────────────────────────────────────────────
# Required for all cron endpoints. Generate with: openssl rand -hex 32
CRON_SECRET=""

# ── CORS ─────────────────────────────────────────────────────────────
# Comma-separated origins for /api/leads/inbound webhook CORS
CORS_ALLOWED_ORIGINS=""
# Comma-separated origins for /api/embed/submit (leave blank to allow all)
EMBED_ALLOWED_ORIGINS=""

# ── Error Tracking (Phase 4) ───────────────────────────────────────
# SENTRY_DSN=""

# ── Analytics (free tier: Umami Cloud) ─────────────────────────────
NEXT_PUBLIC_UMAMI_WEBSITE_ID=""
NEXT_PUBLIC_UMAMI_SCRIPT_URL="https://cloud.umami.is/script.js"
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST=""

# ── Erie.Pro persona chatbot (open-weight LLM) ─────────────────────
# Provider: openrouter | groq | anthropic | ollama
# Auto-detect order (when CHAT_LLM_PROVIDER unset): OpenRouter → Groq → Ollama
# Anthropic is used only when CHAT_LLM_PROVIDER=anthropic (not auto-selected)
CHAT_LLM_PROVIDER=""
CHAT_LLM_MODEL=""
# Production default: OpenRouter + Llama 3.3 70B (or set CHAT_LLM_MODEL)
OPENROUTER_API_KEY=""
# Fast inference alternative
GROQ_API_KEY=""
# Optional Claude fallback (explicit provider only)
ANTHROPIC_API_KEY=""
# Local dev: Ollama OpenAI-compatible API
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_API_KEY=""

# ── Optional live chat embed (Pickaxe/Crisp script URL) ────────────
NEXT_PUBLIC_CHAT_WIDGET_URL=""

# ── SEO publish gate (noindex thin pages until plans are Go) ───────
# SEO_PUBLISH_GATE="1"
# SEO_PILOT_INDEX_OVERRIDE="1"
# SEO_AREA_MATRIX_MODE="pilot"  # pilot | full — SSG scale for /[niche]/areas/[area]
# SEO_AREA_MATRIX_INDEX="1"     # set to 0 to noindex all area matrix pages
# SEO_MODIFIER_INDEX="1"        # set to 0 to noindex /[niche]/modifiers/*
# Branded Maps search until a verified GBP is claimed (see npm run org:resolve-gbp)
# NEXT_PUBLIC_GOOGLE_BUSINESS_PROFILE_URL="https://www.google.com/maps/search/?api=1&query=Erie.Pro+Erie%2C+PA"
# NEXT_PUBLIC_NAP_STREET_ADDRESS=""
# NEXT_PUBLIC_NAP_POSTAL_CODE="16501"
# NEXT_PUBLIC_FACEBOOK_URL=""
# NEXT_PUBLIC_BBB_URL=""

# ── Outscraper (directory scraping) ────────────────────────────────
# Only needed when running the scraper script, not at Next.js runtime
OUTSCRAPER_API_KEY=""

# ── Google Places (optional — only for photo proxy of legacy data) ─
# GOOGLE_PLACES_API_KEY=""

# ── Multi-City (Phase 5) ───────────────────────────────────────────
# CITY_SLUG="erie"

# Boost.space universal lead intake
# Webhook URL is optional fallback. API token writes directly to the Universal Lead Event space.
BOOST_SPACE_LEAD_WEBHOOK_URL=""
BOOST_SPACE_API_TOKEN=""
# BOOST_SPACE_API_KEY="" also works if the token already exists under that shared Vercel name.
BOOST_SPACE_API_BASE_URL="https://neatcircle.boost.space/api"
BOOST_SPACE_LEAD_EVENT_SPACE_ID="5"
BOOST_SPACE_LEAD_EVENT_STATUS_SYSTEM_ID="94"
# Dedicated token for Boost.space revenue action polling/callbacks.
# Falls back to REVENUE_ACTIONS_API_TOKEN when blank.
BOOST_SPACE_REVENUE_ACTION_TOKEN=""
REVENUE_ACTIONS_API_TOKEN=""

# SuiteDash Secure API for the YOURDEPUTY tenant.
# Erie.Pro prefers these tenant-specific names, then falls back to SUITEDASH_PUBLIC_ID/SUITEDASH_SECRET_KEY.
SUITEDASH_YOURDEPUTY_PUBLIC_ID=""
SUITEDASH_YOURDEPUTY_SECRET_KEY=""
# Optional bearer token for /api/integrations/suitedash/revenue-actions; falls back to REVENUE_ACTIONS_API_TOKEN.
SUITEDASH_REVENUE_ACTION_TOKEN=""
# ConvertBox site installation UUID for the erie.pro ConvertBox site.
# Public visitor-side identifier only; do not put ConvertBox login credentials here.
NEXT_PUBLIC_CONVERTBOX_UUID="d2c3d694-a219-4659-a17f-93165afe8ba0"
CONVERTBOX_WEBHOOK_SECRET=""

# Provider Offer System (Local Authority Microsites)
FEATURE_PROVIDER_OFFERS="1"
# Keep 0 until publish-gate QA passes — blocks auto live microsites when 0
FEATURE_MICROSITE_AUTO_PUBLISH="0"
