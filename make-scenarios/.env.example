# ════════════════════════════════════════════════════════════════
# Make-Scenarios Environment Variables
# Copy this file to .env and fill in the values.
# ════════════════════════════════════════════════════════════════

# Boost.space (Make.com) API token — REQUIRED for all deploy scripts
MAKE_API_TOKEN=

# ── Discord Webhook URLs ──
DISCORD_WEBHOOK_NEW_LEADS=
DISCORD_WEBHOOK_ERRORS=
DISCORD_WEBHOOK_WINS=
DISCORD_WEBHOOK_HIGH_VALUE=

# ── Telegram Bot ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_NEW_LEADS_CHAT=
TELEGRAM_ERRORS_CHAT=
TELEGRAM_WINS_CHAT=
TELEGRAM_HIGH_VALUE_CHAT=

# ── Emailit (transactional email) ──
EMAILIT_API_KEY=

# ── AITable (event logging / CRM) ──
AITABLE_API_TOKEN=
AITABLE_DATASHEET_ID=

# ── WbizTool (WhatsApp) ──
WBIZTOOL_API_KEY=
WBIZTOOL_INSTANCE_ID=

# ── Optional ──
# UPVIRAL_CAMPAIGN_URL=https://refer.neatcircle.com
